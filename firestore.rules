rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /appData/{userId} {
      allow read, update, delete: if request.auth != null
        && request.auth.token.email == userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.id;
    }
    match /pushSubscriptions/{userId} {
      allow read, delete: if request.auth != null
        && request.auth.token.email == userId;
      allow create, update: if request.auth != null
        && request.auth.token.email == userId
        && request.resource.data.token is string;
    }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == userId;
    }
    match /pairingCodes/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == userId;
    }
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.from == request.auth.token.email;
      allow delete: if request.auth != null && resource.data.from == request.auth.token.email;
    }
  }
}
